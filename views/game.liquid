<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Score a Game</title>
    <link rel="stylesheet" href="/styleGame.css">
</head>
<body>

<header>

    <h1>Keep the Score</h1>

  </header>



  <main>

    <h2>Game</h2>

    <!-- Score form met action naar de route /score -->

   <form method="post" action="/score">

    <fieldset>
      <legend>Team A</legend>
      <label>
        <span>Punten:</span>
        <input type="number" name="score_team_1" placeholder="score" value="{{ scores[0].score_team_1 }}">
      </label>
    </fieldset>

    <fieldset>
      <legend>Team B</legend>
      <label>
        <span>Punten:</span>
        <input type="number" name="score_team_2" placeholder="score" value="{{ scores[0].score_team_2 }}">
      </label>
    </fieldset>
    
    <button type="submit">Save score</button>
    
    </form>

  </main>

    {% comment %} 
      Scores met in de loop de partial score.liquid 
    {% endcomment %}

    <section id="score">
      <h2>Scoreverloop</h2>

      <ol class="scores">

        {% for score in scores %}          
          {% render 'partials/score.liquid', score: score %}
        {% else %}
          <p>Er is nog niet gescoord.</p>
        {% endfor %}

      </ol>

    </section>

  



<!-- Client-Side script voor enhancement -->
<!-- type="module" is een feature detection
      browsers die dat ondersteuenen, ondersteunen ook fetch (en andere js methoden) 
      https://snugug.com/musings/modern-cutting-the-mustard/
-->
<script type="module">

  const scoreForm = document.querySelector("form")
  const formButton = document.querySelector("form button")
  const scores = document.querySelector("#score ol")
  // console.log(scores)


  // Als er op de submit button wordt geklikt ...
  scoreForm.addEventListener("submit", async function(event) {
    console.log("Post score: Button submit")
    // Voorkom de standaard submit van de browser
    // Let op: hiermee overschrijven we de default Loading state van de browser...
    event.preventDefault()

    
    //Loading state tonen:
    console.log("Loading state tonen")
    formButton.classList.add("loading")
    formButton.textContent = "loading..."

    //formdata voorbereiden:
    let formData = new FormData(scoreForm);    
    // console.log(formData)
    // for (const [key, value] of formData) {
    //   console.log(key, value);
    // }

    // Data fetchen:
    // Doe een fetch naar de server, net als hoe de browser dit normaal zou doen
    // Gebruik daarvoor het action en method attribuut van het formulier
    // Stuur de formulierelementen mee
    console.log("Data fetchen")
    const response = await fetch(scoreForm.action, {
      method: scoreForm.method, //POST dus
      body: new URLSearchParams(formData) // <<< Dit moet omdat server.js anders niet met de formulier data kan werken
    })

    // Data verwerken:
    // De server.js geeft de pagina terug als het posten goed gaat
    console.log("Data verwerken")
    const responseData = await response.text()
    console.log("responseData - HTML pagina van server.js",responseData)

    // Normaal zou de browser die HTML parsen en weergeven, maar daar moeten we nu zelf iets mee
    // Parse de nieuwe HTML en maak hiervan een nieuw Document Object Model in het geheugen
    const parser = new DOMParser()
    const responseDOM = parser.parseFromString(responseData, 'text/html')

    console.log("responseDOM - Onderwater HTML",responseDOM)

    // Zoek in die nieuwe HTML DOM onze nieuwe UI state op, die we via Liquid hebben klaargemaakt
    const newScores = responseDOM.querySelector('.scores')
    console.log("newScores",newScores)

    // data van de server toevoegen aan de DOM, aan de scorelijst in de ol
    // Overschrijf de HTML met de nieuwe HTML
    console.log("Data toevoegen aan de DOM")
    scores.innerHTML = newScores.innerHTML

    // Loading state weghalen
    // Nu kan je waarschijnlijk de Loading state vervangen door een Success state
    console.log("Loading state weghalen")
    formButton.classList.remove("loading")
    formButton.textContent = "Save score"

  })

</script>






</body>
</html>



{% comment %} 
<!-- Debug Data ding -->

    <details>
      <summary>Data</summary>
      Messages
      <pre>{{ messages | json:4 }}</pre>
    </details> 
{% endcomment %}





