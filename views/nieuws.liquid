{% render 'partials/head.liquid' %}

 <main class="nieuws">

    <div class="terug-knop">
        <a href="/"><img src="/assets/pijltje-terug.svg" width="20" height="20" alt="pijltje terug">Terug</a>
    </div>

    <h1>Veld nieuws</h1>


    {% comment %} 3 FILTERKNOPPEN {% endcomment %}
    <div class="navigatie-buttons">
        <a href="/nieuws" class="sort-button alle {% if activeSort == 'alle' %}is-active{% endif %}">Alle</a>
        <a href="/laatste-oudste" class="sort-button laatste-oudste {% if activeSort == '-date' %}is-active{% endif %}">Laatste</a>
        <a href="/oudste-laatste" class="sort-button sort-button-reverse laatste-oudste {% if activeSort == 'date' %}is-active{% endif %}">Oudste</a>
    </div>
  
    <div class="wrapper">
        <div class="zoekbalk">
            <input class="zoekbalkinput" type="text" name="zoekbalkinput" placeholder="Search" value="">
            <button class="zoekicoon" type="submit" name="zoekicoon" aria-label="Zoeken">
                <svg style="width:24px;height:24px" viewBox="0 0 24 24"><path fill="#666666" d="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" />
                </svg>
            </button>
        </div>
    </div>  

    {% comment %} NIEUWSBERICHTEN {% endcomment %}
    <div class="alle-nieuws"> 

         {% for news in news %}
            <a href="/nieuws/{{ news.slug }}">
                <article class="nieuws-bericht">
                    <picture>
                        <!-- browser gebruikt de .avif als je dit type kent -->
                        <source loading="lazy" type="image/avif" srcset="https://fdnd-agency.directus.app/assets/{{news.image}}?format=avif">
                        <!-- browser gebruikt de .webp als je dit type kent -->
                        <source loading="lazy" type="image/webp" srcset="https://fdnd-agency.directus.app/assets/{{news.image}}?format=webp">
                        <!-- en als je beide niet kent of geen idee hebt wat <source> betekent, doe dan gewoon dit -->
                        <img loading="lazy" src="https://fdnd-agency.directus.app/assets/{{news.image}}" alt="{{news.title}}">
                    </picture>
                    <p class="label">Bloemendveld</p>
                    <h2 class="titel">{{ news.title }}</h2>
                </article>
            </a>

            <hr>
        {% endfor %} 

    </div> 

 </main>

{% render 'partials/navbar.liquid', activeIcon: activeIcon %}

{% render 'partials/foot.liquid' %}